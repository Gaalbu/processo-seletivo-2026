{$APP_DOMAIN:localhost} {
  encode zstd gzip

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
    X-Frame-Options DENY
  }

  handle /api/* {
    reverse_proxy backend:8080
  }

  handle /actuator/health {
    reverse_proxy backend:8080
  }

  handle {
    reverse_proxy frontend:3000
  }
}
